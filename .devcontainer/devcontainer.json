{
  "name": "tokkun-asp-dotnet",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/tokkun-aspnetcore",
  "forwardPorts": [5000, 5432],
  "portsAttributes": {
    "5000": {
      "label": "ASP.NET Core",
      "onAutoForward": "openBrowser"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime",
        "formulahendry.dotnet-test-explorer"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[csharp]": {
          "editor.defaultFormatter": "ms-dotnettools.csharp"
        }
      }
    }
  },
  "remoteEnv": {
    "ConnectionStrings__Default": "Host=db;Port=5432;Database=employeeapp;Username=postgres;Password=postgres"
  },
  "postCreateCommand": "dotnet restore src/EmployeeApp/EmployeeApp.csproj 2>/dev/null || true",
  "remoteUser": "vscode"
}
