@model IEnumerable<EmployeeApp.Models.Employee>

@{
    ViewData["Title"] = "社員一覧";
}

<h1>社員一覧</h1>

<form method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="keyword" value="@ViewData["Keyword"]" class="form-control" placeholder="氏名で検索..." />
        <button type="submit" class="btn btn-outline-secondary">検索</button>
    </div>
</form>

<a asp-action="Create" class="btn btn-primary mb-3">新規登録</a>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>氏名</th>
            <th>部署 ID</th>
            <th>給与</th>
            <th>入社日</th>
            <th>上司 ID</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var employee in Model)
        {
            <tr>
                <td>@employee.Id</td>
                <td>@employee.Name</td>
                <td>@employee.DeptId</td>
                <td>@employee.Salary</td>
                <td>@employee.HireDate</td>
                <td>@employee.ManagerId</td>
                <td>
                    <a asp-action="Details" asp-route-id="@employee.Id">詳細</a>
                </td>
            </tr>
        }
    </tbody>
</table>
